{
    "name": "verisure-backend",
    "version": "1.0.0",
    "type": "module",
    "main": "dist/server.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc --project tsconfig.json",
        "start": "node dist/server.js",
        "db:migrate": "prisma migrate deploy",
        "db:generate": "prisma generate",
        "db:push": "prisma db push",
        "db:studio": "prisma studio",
        "db:seed": "tsx prisma/seed.ts",
        "worker:anchor": "tsx src/workers/anchor.worker.ts",
        "worker:bulk": "tsx src/workers/bulk.worker.ts",
        "worker:email": "tsx src/workers/email.worker.ts",
        "worker:webhook": "tsx src/workers/webhook.worker.ts",
        "worker:expiry": "tsx src/workers/expiry.worker.ts",
        "workers": "concurrently \"npm:worker:*\"",
        "typecheck": "tsc --noEmit",
        "backfill:anchors": "tsx src/scripts/backfill-anchors.ts"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1063.0",
        "@aws-sdk/s3-request-presigner": "^3.1063.0",
        "@fastify/cookie": "^11.0.2",
        "@fastify/cors": "^11.2.0",
        "@fastify/helmet": "^13.0.2",
        "@fastify/rate-limit": "^10.3.0",
        "@fastify/swagger": "^9.7.0",
        "@fastify/swagger-ui": "^5.2.6",
        "@prisma/client": "^5.14.0",
        "bullmq": "^5.7.1",
        "dotenv": "^17.4.2",
        "ethers": "^6.12.1",
        "fastify": "^5.8.5",
        "ioredis": "^5.3.2",
        "jose": "^5.3.0",
        "otplib": "^12.0.1",
        "pino": "^9.2.0",
        "pino-pretty": "^11.2.1",
        "resend": "^6.12.4",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@nomicfoundation/hardhat-ethers": "^4.0.13",
        "@types/node": "^20.14.2",
        "concurrently": "^8.2.2",
        "hardhat": "^3.9.0",
        "prisma": "^5.14.0",
        "tsx": "^4.15.1",
        "typescript": "^5.4.5"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
